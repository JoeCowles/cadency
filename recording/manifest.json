{
  "manifest_version": 3,
  "name": "Bloom",
  "description": "Open-source screen recorder with a draggable camera bubble.",
  "version": "0.1.0",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabCapture",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bloom",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "recorder.html",
        "recorder.js",
        "floating.html",
        "floating.css",
        "floating.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
